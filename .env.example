# ============================================================
# bridgebot — Telegram-to-AI CLI Bridge
# Copy this file to .env and fill in your values
# ============================================================

# === REQUIRED ===
TELEGRAM_BOT_TOKEN=your-bot-token-here
ALLOWED_USER_ID=your-telegram-user-id

# Multiple users (comma-separated):
# ALLOWED_USER_IDS=123456,789012

# Display names per user (optional):
# USER_NAMES=123456:Alice,789012:Bob

# === CLI SELECTION ===
# Which AI CLI to use: claude | gemini | codex | generic
CLI_RUNNER=claude

# Override binary name (auto-detected from CLI_RUNNER if empty):
# CLI_COMMAND=claude

# Timeout in seconds for CLI responses:
CLI_TIMEOUT=1800

# Custom system prompt injected into every conversation:
# CLI_SYSTEM_PROMPT=You are a helpful assistant.

# Bot display name (auto-detected from CLI_RUNNER if empty):
# BOT_NAME=Claude

# === SERVER ===
HOST=0.0.0.0
PORT=8588

# Webhook URL (set by your tunneling solution, e.g. ngrok or cloudflared):
# WEBHOOK_URL=https://your-domain.example.com

# === OPTIONAL FEATURES ===

# ChromaDB vector memory (stores conversation context for retrieval):
MEMORY_ENABLED=true
MEMORY_DIR=~/memories
# MEMORY_COLLECTION=telegram_bridge
# MEMORY_TOP_K=5

# Voice messages (requires faster-whisper + edge-tts + ffmpeg):
# WHISPER_MODEL=base
# EDGE_TTS_VOICE=en-US-AndrewNeural
# VOICE_MAX_LENGTH=3000

# Image generation (requires GEMINI_API_KEY):
# GEMINI_API_KEY=your-gemini-api-key

# Chrome browser extension (Claude only):
# CHROME_ENABLED=false

# SEC EDGAR research (required for /research command — use your real email):
# EDGAR_CONTACT=your@email.com

# Ollama router URL (only needed for multi-instance routing):
# OLLAMA_URL=http://127.0.0.1:11434/api/generate

# === ADVANCED (optional) ===

# Timezone for schedules and proactive agents (IANA format, e.g. America/New_York, Europe/London):
# Defaults to UTC
# TIMEZONE=UTC

# Default model passed to --model flag when creating agents (auto-detected from CLI_RUNNER if empty):
# DEFAULT_AGENT_MODEL=claude-sonnet-4-6

# Daily activity log (writes MEMORY_DIR/Tasks Done/ and MEMORY_DIR/Daily/ — disabled by default):
# DAILY_REPORT_ENABLED=false

# Runtime data directory (session DB, subprocess logs, pid files):
# Defaults to ~/.bridgebot — override to put data elsewhere
# TG_BRIDGE_DATA_DIR=~/.bridgebot

# Voice calls via Pyrogram (requires TG_API_ID + TG_API_HASH):
# TG_API_ID=0
# TG_API_HASH=
# TG_SESSION_NAME=bridge_voice
# CALL_GROUP_ID=0

# === Display Preferences ===
# Controls what users see while the bot is working. Both default to true.
# Can also be changed per-user at any time with /show and /hide commands in Telegram.
# DISPLAY_SHOW_TOOLS=true     # Show tool indicators (⚡ Shell, ✏️ Edit, etc.)
# DISPLAY_SHOW_THOUGHTS=true  # Show thinking/reasoning blocks (💭)

# === Collab (federated peer networking) ===
# Allows multiple bridgebot instances to discover each other, delegate tasks,
# and share memory with tier-based access control.
COLLAB_ENABLED=true
COLLAB_INSTANCE_NAME=my-instance   # your unique name on the collab network (e.g. your first name)
COLLAB_TOKEN=                      # secret token peers must send to reach you (set a strong random value)
