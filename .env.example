# ============================================================
# tg-cli-bridge — Telegram-to-AI CLI Bridge
# Copy this file to .env and fill in your values
# ============================================================

# === REQUIRED ===
TELEGRAM_BOT_TOKEN=your-bot-token-here
ALLOWED_USER_ID=your-telegram-user-id

# Multiple users (comma-separated):
# ALLOWED_USER_IDS=123456,789012

# Display names per user (optional):
# USER_NAMES=123456:Alice,789012:Bob

# === CLI SELECTION ===
# Which AI CLI to use: claude | gemini | codex | generic
CLI_RUNNER=claude

# Override binary name (auto-detected from CLI_RUNNER if empty):
# CLI_COMMAND=claude

# Timeout in seconds for CLI responses:
CLI_TIMEOUT=1800

# Custom system prompt injected into every conversation:
# CLI_SYSTEM_PROMPT=You are a helpful assistant.

# Bot display name (auto-detected from CLI_RUNNER if empty):
# BOT_NAME=Claude

# === SERVER ===
HOST=0.0.0.0
PORT=8585

# Webhook URL (set by your tunneling solution, e.g. ngrok or cloudflared):
# WEBHOOK_URL=https://your-domain.example.com

# === OPTIONAL FEATURES ===

# ChromaDB vector memory (stores conversation context for retrieval):
MEMORY_ENABLED=true
MEMORY_DIR=~/memories
# MEMORY_COLLECTION=telegram_bridge
# MEMORY_TOP_K=5

# Voice messages (requires faster-whisper + edge-tts + ffmpeg):
# WHISPER_MODEL=base
# EDGE_TTS_VOICE=en-US-AndrewNeural
# VOICE_MAX_LENGTH=3000

# Resume PDF path for job search features:
# RESUME_PATH=~/path/to/your/resume.pdf

# Job search / email pipeline personalization:
# USER_FULL_NAME=Your Name
# USER_BACKGROUND=Software engineer with experience building production systems.
# USER_TRUE_FACTS=Worked at Company X only. Based in City. Built systems for N users.
# EMAIL_SIGNATURE=Best regards,\nYour Name\nyour@email.com\nhttps://linkedin.com/in/you

# Image generation (requires GEMINI_API_KEY):
# GEMINI_API_KEY=your-gemini-api-key

# Chrome browser extension (Claude only):
# CHROME_ENABLED=false

# === ADVANCED (optional) ===

# Voice calls via Pyrogram (requires TG_API_ID + TG_API_HASH):
# TG_API_ID=0
# TG_API_HASH=
# TG_SESSION_NAME=bridge_voice
# CALL_GROUP_ID=0
